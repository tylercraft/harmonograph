{
  "manifest_version": 3,
  "name": "Harmonograph",
  "version": "1.0.1",
  "description": "Personal new tab for a freelance frontend developer.",

  "chrome_url_overrides": {
    "newtab": "index.html"
  },

  "permissions": ["identity", "storage"],

  "host_permissions": [
    "https://api.linear.app/*",
    "https://www.googleapis.com/*",
    "https://accounts.google.com/*",
    "https://fonts.googleapis.com/*",
    "https://fonts.gstatic.com/*"
  ],

  "oauth2": {
    "client_id": "575513229294-78lbb6p63a09hkib94cel637263jo0on.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/calendar.readonly"]
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
